MODEL_NAME=claude-sonnet-5
PROMPT_VERSION=v4
MAX_TOKENS=8000

# Provider switch: "anthropic" (default) or "azure"
PROVIDER=azure

# Used only when PROVIDER=azure. AZURE_OPENAI_API_KEY (secret) lives in .env.
# AZURE_OPENAI_ENDPOINT is the "Azure OpenAI endpoint" from the Azure AI
# Foundry resource page (https://<resource>.openai.azure.com/), NOT the
# "Project endpoint" (services.ai.azure.com) — see providers/azure_provider.py.
AZURE_OPENAI_ENDPOINT=https://rosalinda-5478-resource.services.ai.azure.com/openai/v1
# The deployment name you created in Azure AI Foundry (not the base model name).
AZURE_OPENAI_DEPLOYMENT=gpt-5.4
# Check the Azure OpenAI docs for the current stable API version.
#AZURE_OPENAI_API_VERSION=2026-03-05
