MODEL_NAME=claude-sonnet-5
PROMPT_VERSION=v3
MAX_TOKENS=8000

# Provider switch: "anthropic" (default) or "opensource"
PROVIDER=opensource

# Used only when PROVIDER=opensource. Defaults target a local Ollama
# instance running GPT-OSS (ollama pull gpt-oss:20b && ollama serve).
OPENSOURCE_BASE_URL=http://localhost:11434/v1
OPENSOURCE_MODEL=llama3.2:latest
#gpt-oss:20b
