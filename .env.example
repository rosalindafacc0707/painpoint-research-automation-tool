# Copia questo file in .env e inserisci la chiave reale.
# Non committare mai il file .env.

ANTHROPIC_API_KEY=your_api_key_here

# Necessaria SOLO se PROVIDER=azure. E' la "API key" mostrata nella pagina
# della risorsa Azure AI Foundry (stesso valore usato sia per il "Project
# endpoint" che per l'"Azure OpenAI endpoint" — qui usiamo quest'ultimo).
AZURE_OPENAI_API_KEY=
