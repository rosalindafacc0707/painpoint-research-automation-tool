# Copia questo file in .env e inserisci la chiave reale.
# Non committare mai il file .env.

ANTHROPIC_API_KEY=your_api_key_here

# Necessaria SOLO se PROVIDER=opensource punta a un provider hosted
# (Groq, Together, ecc.) invece che a un'istanza locale (Ollama/LM Studio,
# che ignorano questa chiave). Lasciala vuota per l'uso locale.
OPENSOURCE_API_KEY=
